enum TipoContaBancaria {
  CORRENTE
  POUPANCA
}

model Fornecedor {
  id                 String              @id @default(uuid())
  empresaId          String              @default("00000000-0000-0000-0000-000000000001")
  empresa            Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nome               String
  cnpj               String?
  cpf                String?
  email              String?
  telefone           String?
  ramo               String? // material, mao de obra, servico...
  // Endereco completo
  logradouro         String?
  numero             String?
  bairro             String?
  cep                String?
  cidade             String?
  estado             String?
  // Dados bancarios
  banco              String?
  agencia            String?
  conta              String?
  tipoConta          TipoContaBancaria?
  chavePix           String?
  // Condicoes comerciais
