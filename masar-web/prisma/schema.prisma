  documentoIdentificador String?
  origem                 String? // Tag do que originou o lançamento: SOCIO_APORTE, DESPESA_PAGA, ESTORNO, RESET_AJUSTE, SALDO_INICIAL, etc. Null = importado/externo (conciliação).
