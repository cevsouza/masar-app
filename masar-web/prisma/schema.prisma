/// Tenant. Cada construtora cliente e uma Empresa; TODO dado do sistema pendura
/// aqui. O filtro por empresaId e injetado automaticamente pela extensao do
/// Prisma (lib/tenant) — nao depende de cada rota lembrar de filtrar.
model Empresa {
  id    String  @id @default(uuid())
  nome  String
  slug  String  @unique
  cnpj  String? @unique
  ativa Boolean @default(true)

  // --- White label ---
  /// Dominio proprio do cliente (ex.: erp.construtorafulano.com.br). Resolve o
  /// tenant no login quando ha mais de uma empresa na mesma instancia.
  dominio        String? @unique
  logoUrl        String?
  corPrimaria    String  @default("#2563eb")
  corSecundaria  String  @default("#1e293b")
  /// Remetente dos e-mails desta empresa. Cai em EMAIL_FROM quando vazio.
  emailRemetente String?
  /// Destinatarios extras de alerta, separados por virgula.
  emailsAlerta   String?

  // --- Licenciamento ---
  plano           String    @default("PADRAO")
  limiteObras     Int?
  /// EXCECAO negociada ao teto de unidades do plano (ex.: comprou 40 no plano
  /// de 25). Vazio = vale o teto do plano, definido em lib/planos.ts. O teto
  /// mora no codigo porque muda para todos de uma vez; a coluna e o desvio.
  limiteUnidades  Int?
  dataContratacao DateTime?
  dataExpiracao   DateTime?
  /// Mensalidade contratada. E daqui que a geracao mensal de cobrancas tira o
  /// valor; vazio = cliente sem cobranca automatica (cortesia, piloto, a raiz).
  valorMensal     Float?
  /// Dia do mes do vencimento (1-28). Limitado a 28 de proposito: 29/30/31 nao
  /// existem em todo mes e a data escorregaria em fevereiro.
  diaVencimento   Int?

  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  permissoesPapelModulo  PermissaoPapelModulo[]
  users                  User[]
  empreendimentos        Empreendimento[]
  marcoBurocraticos      MarcoBurocratico[]
  clientes               Cliente[]
  insumoPadraos          InsumoPadrao[]
  casas                  Casa[]
  orcamentoCasas         OrcamentoCasa[]
  itemOrcamentos         ItemOrcamento[]
  diarioDeObras          DiarioDeObra[]
  infraestruturaUnidades InfraestruturaUnidade[]
  medicaoCaixas          MedicaoCaixa[]
  corretors              Corretor[]
  contratoVendas         ContratoVenda[]
  contaBancarias         ContaBancaria[]
  socios                 Socio[]
  movimentacaoSocios     MovimentacaoSocio[]
  transacaoFinanceiras   TransacaoFinanceira[]
  logAuditorias          LogAuditoria[]
  documentoAnexos        DocumentoAnexo[]
  notificacaos           Notificacao[]
  cotacaoMaterials       CotacaoMaterial[]
  pontoTrabalhadors      PontoTrabalhador[]
  trabalhadors           Trabalhador[]
  asos                   ASO[]
  entregaEPIs            EntregaEPI[]
  transacaoBancarias     TransacaoBancaria[]
  distratos              Distrato[]
  assinaturaContratos    AssinaturaContrato[]
  usuarioClientes        UsuarioCliente[]
  solicitacaoCompras     SolicitacaoCompra[]
  cotacaoFornecedors     CotacaoFornecedor[]
  fornecedors            Fornecedor[]
  notaFiscalEntradas     NotaFiscalEntrada[]
  ordemCompras           OrdemCompra[]
  movimentacaoEstoques   MovimentacaoEstoque[]
  parametroMCMVs         ParametroMCMV[]
  itemConformidadeMCMVs  ItemConformidadeMCMV[]
  milestones             Milestone[]
  atividadeCronogramas   AtividadeCronograma[]
  linhaBaseObras         LinhaBaseObra[]
  metasEficiencia        MetaEficiencia[]
  dialogoSegurancas      DialogoSeguranca[]
  acidentes              Acidente[]
  checklistsNR           ChecklistNR[]
}

// ============================================================================
// CONTROL PLANE — o plano de CONTROLE, separado do plano de DADOS.
//
// Tudo abaixo desta linha existe FORA do modelo de tenant: nenhum destes
// modelos tem `empresaId` como dono, nenhum é filho de `Empresa`, e a extensão
// de isolamento os ignora de propósito.
//
// A razão é de segurança, não de organização: se o administrador da plataforma
// fosse um `User` de algum tenant, bastaria um ADMIN de construtora escalar
// privilégio para virar administrador de TODOS os clientes. Separando as
// entidades, o código do aplicativo do cliente não tem como assumir um papel
// do control plane — ele nem enxerga esta tabela.
// ============================================================================

/// Administrador da PLATAFORMA (nós). Não pertence a nenhuma construtora.
/// Autentica por cookie próprio (`masar_admin_session`), nunca pelo do staff.
model AdminPlataforma {
  id           String    @id @default(uuid())
  nome         String
  email        String    @unique
  password     String
  ativo        Boolean   @default(true)
  ultimoAcesso DateTime?
  dataCriacao  DateTime  @default(now())

  acessosAssistidos AcessoAssistido[]

  @@index([email])
}

/// Níveis de acesso do control plane, do menos ao mais invasivo.
enum NivelAcessoPlataforma {
  /// Só contagens e saúde das instâncias. Nenhum dado de obra. É o padrão.
  AGREGADO
  /// Cadastro, plano, vigência e faturamento do cliente. Ainda sem conteúdo.
  FICHA
  /// Conteúdo do tenant. Exige motivo, é temporário e fica registrado no log
  /// de auditoria DO PRÓPRIO CLIENTE, onde ele consegue ver.
  CONTEUDO
}

/// Concessão "break-glass": autoriza um admin de plataforma a enxergar o
/// CONTEÚDO de um tenant por tempo limitado e com motivo declarado.
///
/// Existe para que a promessa comercial ("não navego nos seus dados") seja
/// verificável, e não retórica: sem uma concessão válida e não expirada, o
/// acesso ao conteúdo simplesmente não acontece.
model AcessoAssistido {
  id         String          @id @default(uuid())
  adminId    String
  admin      AdminPlataforma @relation(fields: [adminId], references: [id], onDelete: Cascade)
  /// Tenant alvo. É uma referência solta de propósito: este registro é do
  /// control plane e não deve ser apagado junto com a empresa.
  empresaId  String
  motivo     String
  criadoEm   DateTime        @default(now())
  expiraEm   DateTime
  revogadoEm DateTime?

  @@index([adminId])
  @@index([empresaId, expiraEm])
}

/// Situacao de uma cobranca mensal do cliente.
enum StatusCobranca {
  PENDENTE
  PAGA
  CANCELADA
}

/// Cobranca mensal do cliente — o registro de FATURAMENTO, nao um gateway.
///
/// E control plane por uma razao de seguranca, nao de arrumacao: se pendurasse
/// em `empresaId` como dado de tenant, a extensao de isolamento escoparia a
/// tabela e o ADMIN da construtora enxergaria (e poderia alterar) a propria
/// fatura. O que o cliente deve a plataforma e assunto NOSSO sobre ele, nunca
/// dado DELE.
///
/// Deliberadamente sem integracao de pagamento: com um punhado de contratos,
/// PIX e boleto manual resolvem. O que faltava nao era cobrar automaticamente
/// — era nao esquecer de faturar, e saber quem nao pagou.
model Cobranca {
  id        String @id @default(uuid())
  /// Tenant cobrado. Referencia solta, como em AcessoAssistido: o historico
  /// financeiro nao pode sumir junto com a empresa.
  empresaId String

  /// Mes de referencia no formato AAAA-MM. Texto, e nao data, porque a
  /// competencia e um MES, nao um instante — e e o que evita duas cobrancas
  /// do mesmo mes (ver o unique composto abaixo).
  competencia String

  valor          Float
  dataVencimento DateTime
  status         StatusCobranca @default(PENDENTE)
  dataPagamento  DateTime?
  /// Como foi pago, numero do boleto, o que for. Anotacao livre.
  observacao     String?

  dataCriacao     DateTime @default(now())
  dataAtualizacao DateTime @updatedAt

  /// Uma cobranca por cliente por mes. E o que torna a geracao do mes
  /// repetivel sem duplicar — rodar duas vezes nao cobra duas vezes.
  @@unique([empresaId, competencia])
  @@index([status, dataVencimento])
}
