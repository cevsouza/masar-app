  valorRestituido Float
  motivo          String
  dataCriacao     DateTime      @default(now())

  @@index([empresaId])
}

model AssinaturaContrato {
  id             String        @id @default(uuid())
  empresaId      String        @default("00000000-0000-0000-0000-000000000001")
  empresa        Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  contratoId     String        @unique
  contrato       ContratoVenda @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  status         String        @default("PENDENTE") // PENDENTE, ASSINADO, REJEITADO
