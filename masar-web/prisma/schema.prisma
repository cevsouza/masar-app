datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum StatusLegal {
  ESTUDO_VIABILIDADE
  APROVACAO_PREFEITURA
  APROVACAO_CAIXA
  EM_OBRA
}

enum StatusCredito {
  DOCUMENTACAO_PENDENTE
  EM_ANALISE_CAIXA
  APROVADO_CONDICIONADO
  APROVADO
}

enum EtapaJornada {
  CAPTACAO
  SIMULACAO_SICAQ
  UPLOAD_DOCUMENTOS
  APROVACAO_BANCARIA
  ASSINATURA_DIGITAL
  PAGAMENTO_ENTRADA
  CHAVES_ENTREGUES
}

enum StatusObra {
  BACKLOG
  APROVACOES
  INFRAESTRUTURA
  SUPRAESTRUTURA
  INSTALACOES
  ACABAMENTO
  VISTORIA_CAIXA
  CARTORIO
  VISITAS
  CONCLUIDA
}

enum StatusMedicao {
  AGUARDANDO
  PAGA
  GLOSADA_REPROVADA
}

enum TipoMarco {
  ALVARA_PREFEITURA
  PROJETO_CAIXA
  HABITESE
  CND_RECEITA
}

enum UnidadeMedida {
  KG
  SC
  M3
  HORA
  EMPREITADA
}

enum CategoriaInsumo {
  MATERIAL
  EQUIPAMENTO
  MAO_DE_OBRA
  TAXA
}

enum Clima {
  BOM
  CHUVA
  IMPRATICAVEL
}

enum StatusContrato {
  EM_PROSPECCAO
  SIMULACAO
  ANALISE_CAIXA
  ASSINADO_PROVISORIO
  ASSINADO_CAIXA
}

enum TipoMovimentacaoSocio {
  APORTE
  RETIRADA_LUCRO
  PRO_LABORE
}

enum TipoCustoGlobal {
  TERRENO
  PROJETOS
  MARKETING
  OUTRO
}

enum RoleUsuario {
  ADMIN
  FINANCEIRO
  ENGENHARIA
  COMERCIAL
}

enum EscopoCronograma {
  GERAL
  LOTE
}

// Matriz de permissao Papel x Modulo (Fase 5.2). Cada linha diz se um papel
// pode acessar um modulo. A ausencia de linha cai no default (lib/permissoes).
// ADMIN sempre tem tudo (nao entra na matriz). So controla acesso a PAGINAS/menu;
// as rotas de API seguem checando o papel como backstop de seguranca.
model PermissaoPapelModulo {
  id        String      @id @default(uuid())
  role      RoleUsuario
  modulo    String
  permitido Boolean     @default(false)

  @@unique([role, modulo])
}

model User {
  id          String      @id @default(uuid())
  email       String      @unique
  password    String
  nome        String
  role        RoleUsuario @default(COMERCIAL)
  dataCriacao DateTime    @default(now())
}

model Empreendimento {
  id                     String              @id @default(uuid())
  nome                   String
  localizacao            String
  statusLegal            StatusLegal         @default(ESTUDO_VIABILIDADE)
  dataInicio             DateTime?
  dataFim                DateTime?
  orcamento              Float?
  temSondagemSolo        Boolean             @default(false)
  temInfraestruturaBasica Boolean             @default(false)
  endereco               String?
  cep                    String?
  bairro                 String?
  cidade                 String?
  estado                 String?
  latitude               Float?
  longitude              Float?
  areaTotalTerreno       Decimal?
  quantidadeCasasPrevistas Int?
  proprietarioAnteriorTerreno String?
  valorCompraTerreno     Decimal?
  amenidades             String[]
  padraoAreaConstruida   Decimal?
  padraoAreaLote         Decimal?
  padraoQuantidadeQuartos Int                 @default(0)
  padraoQuantidadeSuites  Int                 @default(0)
  padraoQuantidadeBanheiros Int                 @default(0)
  padraoVagasGaragem     Int                 @default(0)
  padraoPossuiQuintal    Boolean             @default(false)
  padraoSalaConjugada    Boolean             @default(false)
  // Aliquota do RET (Regime Especial de Tributacao) em %. Padrao 4%; MCMV social = 1%.
  aliquotaRET            Float               @default(4.0)
  dataCriacao            DateTime            @default(now())
  dataAtualizacao        DateTime            @updatedAt
  casas                  Casa[]
  marcos                 MarcoBurocratico[]
  movimentacoesSocios    MovimentacaoSocio[]
  documentos             DocumentoAnexo[]
  cotacoes               CotacaoMaterial[]
  solicitacoesCompra     SolicitacaoCompra[]
  transacoes             TransacaoFinanceira[]
  milestones             Milestone[]
  atividadesCronograma   AtividadeCronograma[]
  notasFiscaisEntrada    NotaFiscalEntrada[]
}

model MarcoBurocratico {
  id                String         @id @default(uuid())
  empreendimentoId  String
  empreendimento    Empreendimento @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  tipo              TipoMarco
  dataProtocolo     DateTime
  prazoEsperadoDias Int
  dataAprovacaoReal DateTime?
  dataCriacao       DateTime       @default(now())
  dataAtualizacao   DateTime       @updatedAt
}

model Cliente {
  id                 String          @id @default(uuid())
  nome               String
  cpf                String          @unique
  rg                 String?
  contrachequeUrl    String?
  email              String?         @unique
  telefone           String?
  rendaComprovada    Float
  statusCredito      StatusCredito   @default(DOCUMENTACAO_PENDENTE)
  tokenAcessoPortal  String?         @unique
  etapaAtual         EtapaJornada    @default(CAPTACAO)
  dataCriacao        DateTime        @default(now())
  dataAtualizacao    DateTime        @updatedAt
  casas              Casa[]
  contratos          ContratoVenda[]
  documentos         DocumentoAnexo[]
  usuarioCliente     UsuarioCliente?
  transacoes         TransacaoFinanceira[]
}

model InsumoPadrao {
  id             String             @id @default(uuid())
  nome           String             @unique
  unidadeMedida  UnidadeMedida
  categoria      CategoriaInsumo
  // Saldo de estoque em cache (Σ ENTRADA − Σ SAIDA/PERDA). Mutado apenas via
  // lib/estoque.registrarMovimentacaoEstoque, na mesma transacao da movimentacao.
  saldoEstoque       Float          @default(0)
  // Nivel minimo para alerta de reposicao (null = sem alerta configurado).
  nivelMinimoEstoque Float?
  itensOrcamento ItemOrcamento[]
  transacoes     TransacaoFinanceira[]
  solicitacoes   SolicitacaoCompra[]
  movimentacoesEstoque MovimentacaoEstoque[]
}

model Casa {
  id               String                 @id @default(uuid())
  numero           String
  quadra           String
  empreendimentoId String
  empreendimento   Empreendimento         @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  clienteId        String?
  cliente          Cliente?               @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  statusObra       StatusObra             @default(BACKLOG)
  percentualObra   Float                  @default(0.0)
  prazoFisico      DateTime?
  prazoFinanceiro  DateTime?
  obstaculos       String?
  areaConstruida   Decimal?
  areaLote         Decimal?
  valorVendaProjetado Decimal?
  quantidadeQuartos Int                    @default(0)
  quantidadeSuites  Int                    @default(0)
  quantidadeBanheiros Int                    @default(0)
  vagasGaragem     Int                    @default(0)
  possuiQuintal    Boolean                @default(false)
  salaConjugada    Boolean                @default(false)
  liberadaVenda    Boolean                @default(false)
  dataCriacao      DateTime               @default(now())
  dataAtualizacao  DateTime               @updatedAt
  medicoes         MedicaoCaixa[]
  orcamento        OrcamentoCasa?
  transacoes       TransacaoFinanceira[]
  diarios          DiarioDeObra[]
  infraestrutura   InfraestruturaUnidade?
  contrato         ContratoVenda?
  documentos       DocumentoAnexo[]
  pontos           PontoTrabalhador[]
  solicitacoesCompra     SolicitacaoCompra[]
  movimentacoesEstoque   MovimentacaoEstoque[]
  milestones             Milestone[]
  atividadesCronograma   AtividadeCronograma[]
  linhaBase              LinhaBaseObra?
}

model OrcamentoCasa {
  id        String          @id @default(uuid())
  casaId    String          @unique
  casa      Casa            @relation(fields: [casaId], references: [id], onDelete: Cascade)
  itens     ItemOrcamento[]
}

model ItemOrcamento {
  id                    String        @id @default(uuid())
  orcamentoCasaId       String
  orcamentoCasa         OrcamentoCasa @relation(fields: [orcamentoCasaId], references: [id], onDelete: Cascade)
  insumoId              String
  insumo                InsumoPadrao  @relation(fields: [insumoId], references: [id], onDelete: Restrict)
  quantidadePlanejada   Float
  custoUnitarioPrevisto Float
}



model DiarioDeObra {
  id                   String   @id @default(uuid())
  casaId               String
  casa                 Casa     @relation(fields: [casaId], references: [id], onDelete: Cascade)
  data                 DateTime @default(now())
  clima                Clima
  efetivoTrabalhadores Int
  atividadesExecutadas String
  ocorrencias          String
}

model InfraestruturaUnidade {
  id                     String   @id @default(uuid())
  casaId                 String   @unique
  casa                   Casa     @relation(fields: [casaId], references: [id], onDelete: Cascade)
  padraoEnergiaInstalado Boolean  @default(false)
  ligacaoAguaConcluida   Boolean  @default(false)
  fossaFiltroEsgotoConcluido Boolean @default(false)
  numeroMedidorLuz       String?
  numeroMedidorAgua      String?
}

model MedicaoCaixa {
  id                String        @id @default(uuid())
  casaId            String
  casa              Casa          @relation(fields: [casaId], references: [id], onDelete: Cascade)
  percentualMedido  Float
  valorLiberado     Float
  status            StatusMedicao @default(AGUARDANDO)
  checklistSeguranca Json?
  dataMedicao       DateTime      @default(now())
  dataCriacao       DateTime      @default(now())
  dataAtualizacao   DateTime      @updatedAt
}

model Corretor {
  id                 String          @id @default(uuid())
  nome               String
  creci              String          @unique
  comissaoPercentual Float           @default(1.5)
  dataCriacao        DateTime        @default(now())
  contratos          ContratoVenda[]
}

model ContratoVenda {
  id            String                  @id @default(uuid())
  casaId        String                  @unique
  casa          Casa                    @relation(fields: [casaId], references: [id], onDelete: Cascade)
  clienteId     String
  cliente       Cliente                 @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  corretorId    String?
  corretor      Corretor?               @relation(fields: [corretorId], references: [id], onDelete: SetNull)
  valorVenda    Float
  entrada       Float                   @default(0.0)
  financiamento Float                   @default(0.0)
  fgts          Float                   @default(0.0)
  subsidio      Float                   @default(0.0)
  comissaoValor   Float                   @default(0.0)
  comissaoPaga    Boolean                 @default(false)
  status          StatusContrato          @default(EM_PROSPECCAO)
  transacoes      TransacaoFinanceira[]
  dataCriacao     DateTime                @default(now())
  dataAtualizacao DateTime                @updatedAt
  distrato        Distrato?
  assinatura      AssinaturaContrato?
}



model ContaBancaria {
  id              String              @id @default(uuid())
  nome            String              @unique
  saldoAtual      Float               @default(0.0)
  dataCriacao     DateTime            @default(now())
  dataAtualizacao DateTime            @updatedAt
  transacoes      TransacaoBancaria[]
}

model Socio {
  id              String              @id @default(uuid())
  nome            String              @unique
  percentualCotas Float               @default(0.0)
  dataCriacao     DateTime            @default(now())
  movimentacoes   MovimentacaoSocio[]
}

model MovimentacaoSocio {
  id               String                @id @default(uuid())
  socioId          String
  socio            Socio                 @relation(fields: [socioId], references: [id], onDelete: Cascade)
  empreendimentoId String?
  empreendimento   Empreendimento?       @relation(fields: [empreendimentoId], references: [id], onDelete: SetNull)
  tipo             TipoMovimentacaoSocio
  valor            Float
  data             DateTime              @default(now())
}

enum NaturezaFinanceira {
  RECEITA
  DESPESA
}

enum StatusFinanceiro {
  PENDENTE
  PAGO
  ATRASADO
}

enum CategoriaFinanceira {
  TERRENO
  IMPOSTOS
  PROJETOS
  MATERIAL
  MAO_DE_OBRA
  MEDICAO_CAIXA
  ENTRADA_CLIENTE
}

model TransacaoFinanceira {
  id                String              @id @default(uuid())
  descricao         String
  valor             Float
  dataVencimento    DateTime
  dataPagamento     DateTime?
  natureza          NaturezaFinanceira
  status            StatusFinanceiro    @default(PENDENTE)
  categoria         CategoriaFinanceira
  
  empreendimentoId  String
  empreendimento    Empreendimento      @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  
  casaId            String?
  casa              Casa?               @relation(fields: [casaId], references: [id], onDelete: Cascade)
  
  clienteId         String?
  cliente           Cliente?            @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  
  contratoId        String?
  contrato          ContratoVenda?      @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  
  insumoId          String?
  insumo            InsumoPadrao?       @relation(fields: [insumoId], references: [id], onDelete: SetNull)
  
  quantidade        Float?              @default(1)
  
  dataCriacao       DateTime            @default(now())
  dataAtualizacao   DateTime            @updatedAt
}

model LogAuditoria {
  id           String   @id @default(uuid())
  usuarioId    String?
  usuarioNome  String?
  acao         String   
  tabela       String   
  registroId   String?
  valoresAntigos Json?
  valoresNovos   Json?
  data         DateTime @default(now())
}

model DocumentoAnexo {
  id               String              @id @default(uuid())
  nome             String
  caminhoArquivo   String          
  dataVencimento   DateTime?
  status           String              @default("ATIVO") // ATIVO, VENCIDO
  tipo             TipoDocumentoAnexo?
  casaId           String?
  casa             Casa?               @relation(fields: [casaId], references: [id], onDelete: Cascade)
  clienteId        String?
  cliente          Cliente?            @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  empreendimentoId String?
  empreendimento   Empreendimento?     @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  dataCriacao      DateTime            @default(now())
}

model Notificacao {
  id        String   @id @default(uuid())
  usuarioId String
  mensagem  String
  lida      Boolean  @default(false)
  data      DateTime @default(now())
}

model CotacaoMaterial {
  id               String          @id @default(uuid())
  material         String
  quantidade       Float
  fornecedor       String
  valorUnitario    Float
  aprovado         Boolean         @default(false)
  empreendimentoId String
  empreendimento   Empreendimento @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  dataCriacao      DateTime        @default(now())
  dataAtualizacao  DateTime        @updatedAt
}

model PontoTrabalhador {
  id             String   @id @default(uuid())
  trabalhadorNome String
  trabalhadorCpf  String
  trabalhadorId  String?
  trabalhador    Trabalhador? @relation(fields: [trabalhadorId], references: [id])
  casaId         String
  casa           Casa     @relation(fields: [casaId], references: [id], onDelete: Cascade)
  tipo           String   // ENTRADA, SAIDA
  dataRegistro   DateTime @default(now())
}

enum TipoVinculo {
  PROPRIO
  TERCEIRO
  EMPREITEIRO
}

// Cadastro (registry) de trabalhador da obra — base do modulo de SST. ASO, EPI,
// DDS, CAT e o ponto do canteiro referenciam este cadastro.
model Trabalhador {
  id              String            @id @default(uuid())
  nome            String
  cpf             String?           @unique
  rg              String?
  funcao          String? // pedreiro, servente, mestre de obras...
  tipoVinculo     TipoVinculo       @default(PROPRIO)
  empresa         String? // empreiteira/terceirizada (quando nao for proprio)
  telefone        String?
  dataAdmissao    DateTime?
  observacoes     String?
  ativo           Boolean           @default(true)
  dataCriacao     DateTime          @default(now())
  dataAtualizacao DateTime          @updatedAt
  pontos          PontoTrabalhador[]
  asos            ASO[]
  episEntregues   EntregaEPI[]
}

enum TipoASO {
  ADMISSIONAL
  PERIODICO
  RETORNO_AO_TRABALHO
  MUDANCA_DE_FUNCAO
  DEMISSIONAL
}

enum ResultadoASO {
  APTO
  APTO_COM_RESTRICAO
  INAPTO
}

// ASO — Atestado de Saude Ocupacional (exame). A validade dispara alerta no cron
// e, na Fase 3.4, trava a liberacao de medicao se estiver vencida.
model ASO {
  id             String       @id @default(uuid())
  trabalhadorId  String
  trabalhador    Trabalhador  @relation(fields: [trabalhadorId], references: [id], onDelete: Cascade)
  tipo           TipoASO      @default(PERIODICO)
  dataRealizacao DateTime
  dataValidade   DateTime
  resultado      ResultadoASO @default(APTO)
  medico         String? // medico/clinica emitente
  observacoes    String?
  dataCriacao    DateTime     @default(now())
}

// Entrega de EPI (equipamento de protecao individual) a um trabalhador.
model EntregaEPI {
  id             String      @id @default(uuid())
  trabalhadorId  String
  trabalhador    Trabalhador @relation(fields: [trabalhadorId], references: [id], onDelete: Cascade)
  equipamento    String // capacete, botina, luva, cinto...
  ca             String? // Certificado de Aprovacao
  quantidade     Int         @default(1)
  dataEntrega    DateTime
  dataValidade   DateTime? // validade do EPI/CA (opcional)
  devolvido      Boolean     @default(false)
  observacoes    String?
  dataCriacao    DateTime    @default(now())
}

model TransacaoBancaria {
  id                   String        @id @default(uuid())
  contaBancariaId      String
  contaBancaria        ContaBancaria @relation(fields: [contaBancariaId], references: [id], onDelete: Cascade)
  data                 DateTime
  valor                Float
  descricao            String
  tipo                 String        // CREDITO, DEBITO
  conciliado           Boolean       @default(false)
  documentoIdentificador String?     @unique
  origem               String?       // Tag do que originou o lançamento: SOCIO_APORTE, DESPESA_PAGA, ESTORNO, RESET_AJUSTE, SALDO_INICIAL, etc. Null = importado/externo (conciliação).
  dataCriacao          DateTime      @default(now())
}

model Distrato {
  id              String        @id @default(uuid())
  contratoId      String        @unique
  contrato        ContratoVenda @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  data            DateTime      @default(now())
  multaCisao      Float
  valorRestituido Float
  motivo          String
  dataCriacao     DateTime      @default(now())
}

model AssinaturaContrato {
  id             String        @id @default(uuid())
  contratoId     String        @unique
  contrato       ContratoVenda @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  status         String        @default("PENDENTE") // PENDENTE, ASSINADO, REJEITADO
  dataAssinatura DateTime?
  externalId     String?       // Token da ZapSign
  dataCriacao    DateTime      @default(now())
}

model UsuarioCliente {
  id          String   @id @default(uuid())
  clienteId   String   @unique
  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  email       String   @unique
  password    String
  dataCriacao DateTime @default(now())
}

model SolicitacaoCompra {
  id                   String              @id @default(uuid())
  casaId               String?
  casa                 Casa?               @relation(fields: [casaId], references: [id], onDelete: Cascade)
  empreendimentoId     String?
  empreendimento       Empreendimento?     @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  insumoId             String
  insumo               InsumoPadrao        @relation(fields: [insumoId], references: [id], onDelete: Restrict)
  quantidadeSolicitada Float
  status               String              @default("PENDENTE") // PENDENTE, EM_COTACAO, APROVADA, REJEITADA
  dataNecessidade      DateTime
  tokenCotacao         String              @unique
  cotacoes             CotacaoFornecedor[]
  dataCriacao          DateTime            @default(now())
}

model CotacaoFornecedor {
  id               String            @id @default(uuid())
  solicitacaoId    String
  solicitacao      SolicitacaoCompra @relation(fields: [solicitacaoId], references: [id], onDelete: Cascade)
  fornecedorNome   String
  fornecedorId     String?
  fornecedor       Fornecedor?       @relation(fields: [fornecedorId], references: [id])
  valorUnitario    Float
  prazoEntregaDias Int
  comprovanteUrl   String?
  ordemCompra      OrdemCompra?
  dataCriacao      DateTime          @default(now())
}

enum TipoContaBancaria {
  CORRENTE
  POUPANCA
}

model Fornecedor {
  id                 String              @id @default(uuid())
  nome               String
  cnpj               String?             @unique
  cpf                String?             @unique
  email              String?
  telefone           String?
  ramo               String? // material, mao de obra, servico...
  // Endereco completo
  logradouro         String?
  numero             String?
  bairro             String?
  cep                String?
  cidade             String?
  estado             String?
  // Dados bancarios
  banco              String?
  agencia            String?
  conta              String?
  tipoConta          TipoContaBancaria?
  chavePix           String?
  // Condicoes comerciais
  prazoPagamentoDias Int? // prazo padrao de pagamento
  prazoEntregaDias   Int? // prazo tipico de entrega
  avaliacao          Int? // nota 1-5
  observacoes        String?
  ativo              Boolean             @default(true)
  dataCriacao        DateTime            @default(now())
  dataAtualizacao    DateTime            @updatedAt
  cotacoes           CotacaoFornecedor[]
  notasEntrada       NotaFiscalEntrada[]
}

// NF-e de entrada (compra): importada por XML, gera conta a pagar e, quando os
// itens casam com o catalogo, entrada de estoque. Base do modulo Fiscal (Fase 4).
model NotaFiscalEntrada {
  id               String          @id @default(uuid())
  chave            String?         @unique // chave de acesso (44 digitos)
  numero           String?
  serie            String?
  emitenteCnpj     String?
  emitenteNome     String?
  valorTotal       Float
  dataEmissao      DateTime?
  fornecedorId     String?
  fornecedor       Fornecedor?     @relation(fields: [fornecedorId], references: [id])
  empreendimentoId String?
  empreendimento   Empreendimento? @relation(fields: [empreendimentoId], references: [id], onDelete: SetNull)
  contaPagarId     String? // TransacaoFinanceira (conta a pagar) gerada
  itensGeraramEstoque Int          @default(0)
  itens            Json? // itens parseados do XML
  dataCriacao      DateTime        @default(now())
}

model OrdemCompra {
  id                  String            @id @default(uuid())
  cotacaoId           String            @unique
  cotacao             CotacaoFornecedor @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  usuarioAprovadorId  String?
  statusEntrega       String            @default("PENDENTE") // PENDENTE, ENTREGUE
  excepcionalAprovado Boolean           @default(false)
  dataCriacao         DateTime          @default(now())
}

model MovimentacaoEstoque {
  id               String       @id @default(uuid())
  insumoId         String
  insumo           InsumoPadrao @relation(fields: [insumoId], references: [id], onDelete: Restrict)
  quantidade       Float
  tipo             String       // ENTRADA, SAIDA, PERDA
  casaId           String?
  casa             Casa?        @relation(fields: [casaId], references: [id], onDelete: SetNull)
  dataMovimentacao DateTime     @default(now())
}

enum TipoDocumentoAnexo {
  PROJETO_ARQUITETONICO
  PROJETO_ESTRUTURAL
  PROJETO_HIDRAULICO
  PROJETO_ELETRICO
  MATRICULA_TERRENO
  ALVARA_LOTEAMENTO
  OUTRO
}

model Milestone {
  id               String          @id @default(uuid())
  titulo           String
  descricao        String?
  categoria        String          @default("PROJETO") // PROJETO, OBRA, COMERCIAL, FINANCEIRO
  dataLimite       DateTime
  dataConclusao    DateTime?
  concluido        Boolean         @default(false)
  empreendimentoId String?
  empreendimento   Empreendimento? @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  casaId           String?
  casa             Casa?           @relation(fields: [casaId], references: [id], onDelete: Cascade)
  dataCriacao      DateTime        @default(now())
  dataAtualizacao  DateTime        @updatedAt
}

model AtividadeCronograma {
  id                 String           @id @default(uuid())
  titulo             String
  descricao          String?
  escopo             EscopoCronograma
  status             StatusObra       @default(BACKLOG)
  ordem              Int              @default(0)
  dataInicioPrevista DateTime
  dataFimPrevista    DateTime
  dataInicioReal     DateTime?
  dataFimReal        DateTime?
  percentualConcluido Float           @default(0)
  empreendimentoId   String
  empreendimento     Empreendimento   @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  casaId             String?
  casa               Casa?            @relation(fields: [casaId], references: [id], onDelete: Cascade)
  dataCriacao        DateTime         @default(now())
  dataAtualizacao    DateTime         @updatedAt

  @@index([empreendimentoId])
  @@index([casaId])
}

// Linha de base congelada da obra (Fase 6.2b): snapshot do plano (orcado +
// prazo + itens) num instante, para medir o DRIFT do plano ao longo do tempo
// (o quanto o orcamento/cronograma mudou desde o congelamento). 1:1 com Casa.
model LinhaBaseObra {
  id                  String    @id @default(uuid())
  casaId              String    @unique
  casa                Casa      @relation(fields: [casaId], references: [id], onDelete: Cascade)
  orcadoBaseline      Float     @default(0)
  prazoInicioBaseline DateTime?
  prazoFimBaseline    DateTime?
  itensBaseline       Json? // snapshot [{insumoId, nome, quantidade, custoUnitario}]
  dataSnapshot        DateTime  @default(now())
  dataAtualizacao     DateTime  @updatedAt
}

// Metas de eficiencia da construtora (config singleton, id fixo "default").
// Base do painel de eficiencia diaria e dos alertas do cron (Fase 6.5).
model MetaEficiencia {
  id                String   @id @default("default")
  cpiMinimo         Float    @default(0.95) // custo: EV/AC minimo aceitavel
  spiMinimo         Float    @default(0.95) // prazo: EV/PV minimo aceitavel
  maxInsumosEstouro Int      @default(0)    // quantos insumos em estouro fisico toleramos
  alertarRuptura    Boolean  @default(true) // alerta se ha ruptura de caixa projetada
  dataAtualizacao   DateTime @updatedAt
}
