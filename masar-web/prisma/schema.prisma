// ── Conformidade MCMV / Caixa ────────────────────────────────────────────────

enum FaixaMCMV {
  FAIXA_1
  FAIXA_2
  FAIXA_3
  FAIXA_4
}

enum StatusConformidade {
  PENDENTE
  EM_ANDAMENTO
  CONFORME
  NAO_CONFORME
  NAO_APLICAVEL
}

// Parametros regulatorios da Caixa por faixa (teto de valor, area minima,
// % de unidades acessiveis). Defaults semeados; editaveis por ADMIN e
// atualizaveis por consulta de IA (portaria vigente). 1 linha por faixa.
model ParametroMCMV {
  id                           String    @id @default(uuid())
  empresaId                    String    @default("00000000-0000-0000-0000-000000000001")
  empresa                      Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  faixa                        FaixaMCMV
  tetoValorImovel              Decimal
  areaUtilMinima               Decimal
  percentualUnidadesAcessiveis Float     @default(3)
  portariaReferencia           String?
  dataVigencia                 DateTime?
  fonteUrl                     String?
  atualizadoPor                String?
  atualizadoEm                 DateTime  @updatedAt
  dataCriacao                  DateTime  @default(now())

  @@unique([empresaId, faixa])
  @@index([empresaId])
}

// Estado de cada item do checklist de conformidade por empreendimento. O
// catalogo (lib/mcmv/catalogo.ts) e a fonte da verdade de titulo/categoria/
// obrigatorio/tipoAvaliacao; aqui guardamos apenas o ESTADO (status manual,
// evidencia e observacao). Itens AUTO/DOC tem o status recalculado na leitura.
model ItemConformidadeMCMV {
  id               String             @id @default(uuid())
  empresaId        String             @default("00000000-0000-0000-0000-000000000001")
  empresa          Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  empreendimentoId String
  empreendimento   Empreendimento     @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  chave            String
  status           StatusConformidade @default(PENDENTE)
  observacao       String?
  documentoId      String?
  dataVerificacao  DateTime?
  verificadoPor    String?
  dataCriacao      DateTime           @default(now())
  dataAtualizacao  DateTime           @updatedAt

  @@unique([empreendimentoId, chave])
  @@index([empreendimentoId])
  @@index([empresaId])
}

model Milestone {
  id               String          @id @default(uuid())
  empresaId        String          @default("00000000-0000-0000-0000-000000000001")
  empresa          Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  titulo           String
  descricao        String?
  categoria        String          @default("PROJETO") // PROJETO, OBRA, COMERCIAL, FINANCEIRO
  dataLimite       DateTime
  dataConclusao    DateTime?
  concluido        Boolean         @default(false)
  empreendimentoId String?
  empreendimento   Empreendimento? @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  casaId           String?
  casa             Casa?           @relation(fields: [casaId], references: [id], onDelete: Cascade)
  dataCriacao      DateTime        @default(now())
  dataAtualizacao  DateTime        @updatedAt

  @@index([empresaId])
}

model AtividadeCronograma {
  id                  String           @id @default(uuid())
  empresaId           String           @default("00000000-0000-0000-0000-000000000001")
  empresa             Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  titulo              String
  descricao           String?
  escopo              EscopoCronograma
  status              StatusObra       @default(BACKLOG)
  ordem               Int              @default(0)
  dataInicioPrevista  DateTime
  dataFimPrevista     DateTime
  dataInicioReal      DateTime?
  dataFimReal         DateTime?
  percentualConcluido Float            @default(0)
  empreendimentoId    String
  empreendimento      Empreendimento   @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  casaId              String?
  casa                Casa?            @relation(fields: [casaId], references: [id], onDelete: Cascade)
  dataCriacao         DateTime         @default(now())
  dataAtualizacao     DateTime         @updatedAt

  @@index([empreendimentoId])
  @@index([casaId])
  @@index([empresaId])
}

// Linha de base congelada da obra (Fase 6.2b): snapshot do plano (orcado +
// prazo + itens) num instante, para medir o DRIFT do plano ao longo do tempo
// (o quanto o orcamento/cronograma mudou desde o congelamento). 1:1 com Casa.
model LinhaBaseObra {
  id                  String    @id @default(uuid())
  empresaId           String    @default("00000000-0000-0000-0000-000000000001")
  empresa             Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  casaId              String    @unique
  casa                Casa      @relation(fields: [casaId], references: [id], onDelete: Cascade)
  orcadoBaseline      Float     @default(0)
  prazoInicioBaseline DateTime?
  prazoFimBaseline    DateTime?
  itensBaseline       Json? // snapshot [{insumoId, nome, quantidade, custoUnitario}]
  dataSnapshot        DateTime  @default(now())
  dataAtualizacao     DateTime  @updatedAt

  @@index([empresaId])
}

// Metas de eficiencia da construtora (config singleton, id fixo "default").
// Base do painel de eficiencia diaria e dos alertas do cron (Fase 6.5).
model MetaEficiencia {
  id                String   @id @default("default")
  empresaId         String   @default("00000000-0000-0000-0000-000000000001")
  empresa           Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cpiMinimo         Float    @default(0.95) // custo: EV/AC minimo aceitavel
  spiMinimo         Float    @default(0.95) // prazo: EV/PV minimo aceitavel
  maxInsumosEstouro Int      @default(0) // quantos insumos em estouro fisico toleramos
  alertarRuptura    Boolean  @default(true) // alerta se ha ruptura de caixa projetada
  dataAtualizacao   DateTime @updatedAt

  @@unique([empresaId])
  @@index([empresaId])
}

// ── Registros documentais de SST (Fase 3.3) ──────────────────────────────────

enum TipoAcidente {
  TIPICO
  TRAJETO
  DOENCA_OCUPACIONAL
}

enum GravidadeAcidente {
