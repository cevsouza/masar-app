# Copie para `.env` (que e gitignored) e ajuste. NUNCA commite o .env real.
#
# DESENVOLVIMENTO LOCAL: aponta para o Postgres do docker-compose (porta 5432).
# Use este para rodar `prisma migrate dev` e testar migrations com seguranca,
# SEM tocar na producao. Suba o banco com:  docker compose up -d postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/masar"

# Producao usa a env var DATABASE_URL do Railway (nao vai no .env).
# Para rodar comandos pontuais contra prod (ex: pg_restore de teste, migrate
# status), exporte a DATABASE_PUBLIC_URL do Railway na hora, no shell — nao aqui.

# Segredos de features (so se for rodar localmente as features que os exigem):
# RESEND_API_KEY=""
# JWT_SECRET=""
# CRON_SECRET=""
# SEED_SECRET=""
# SEED_ADMIN_PASSWORD=""
# WEBHOOK_SECRET=""
